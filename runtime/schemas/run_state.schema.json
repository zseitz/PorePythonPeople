{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nanopore-runtime/run-state",
  "title": "RunState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "request",
    "status",
    "current_stage",
    "stage_history",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "request": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["running", "failed", "blocked", "completed", "cancelled"]
    },
    "current_stage": { "type": "string", "minLength": 1 },
    "stage_history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage_id", "status", "timestamp"],
        "properties": {
          "stage_id": { "type": "string" },
          "status": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "note": { "type": "string" }
        }
      }
    },
    "artifacts_dir": { "type": "string" },
    "events_file": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
