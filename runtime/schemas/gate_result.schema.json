{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nanopore-runtime/gate-result",
  "title": "GateResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "stage_id", "gate_id", "status", "checked_at"],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "stage_id": { "type": "string", "minLength": 1 },
    "gate_id": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["pass", "fail", "waived"] },
    "details": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["waiver_id", "reason", "approver"],
      "properties": {
        "waiver_id": { "type": "string" },
        "reason": { "type": "string" },
        "approver": { "type": "string" },
        "scope": { "type": "string" }
      }
    },
    "checked_at": { "type": "string", "format": "date-time" }
  }
}
