{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nanopore-runtime/handoff-packet",
  "title": "HandoffPacket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "from_stage",
    "to_stage",
    "summary",
    "artifacts",
    "acceptance_criteria",
    "created_at"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "from_stage": { "type": "string", "minLength": 1 },
    "to_stage": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "path"],
        "properties": {
          "type": { "type": "string" },
          "path": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        }
      }
    },
    "quality_signals": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "require_refactor": { "type": "boolean" }
      }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
